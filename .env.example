# Copy this file to ".env" and fill in your keys. Do NOT commit .env (it's gitignored).
# Or set them as PowerShell env vars instead, e.g.:
#   $env:MUSIXMATCH_API_KEY="..."

MUSIXMATCH_API_KEY=your_musixmatch_apikey_here   # from musicathon.replit.app/onboarding
LALAI_LICENSE_KEY=your_lalalai_license_key_here  # from the #lalala-ai channel
CYANITE_API_TOKEN=your_cyanite_bearer_token_here # from the Cyanite dashboard

# Optional — only if you do the ElevenLabs voice stretch:
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
